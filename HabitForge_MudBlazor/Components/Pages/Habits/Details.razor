@page "/Habits/Details/{HabitId:int}"
@using HabitForge_MudBlazor.Models
@using HabitForge_MudBlazor.Services
@using MudBlazor

@inject HabitService habitService
@inject NavigationManager NavigationManager
@inject ISnackbar snackbar
@inject NavbarAsHeaderService NavbarAsHeader

@if (habit == null)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
        <MudGrid Justify="Justify.Center">
            <MudItem xs="12" Class="d-flex justify-center">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
            </MudItem>
        </MudGrid>
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-2">

        <!-- Header with habit name and basic info -->
        <MudPaper Elevation="4" Class="rounded pa-3 mb-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <div>
                        <MudText Typo="Typo.h6">@habit.Name</MudText>
                        @if (!string.IsNullOrWhiteSpace(habit.Description))
                        {
                            <MudText Typo="Typo.body2" >@habit.Description</MudText>
                        }
                    </div>
                </MudStack>
                <MudStack Row="true" Spacing="1">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@habit.HabitType</MudChip>
                    <MudChip T="string" Size="Size.Small" Color="@(habit.IsGoodHabit? Color.Success: Color.Error)" Variant="Variant.Outlined">
                        @(habit.IsGoodHabit ? "Good Habit" : "Bad Habit")
                    </MudChip>
                    @if (habit.Category != null)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@habit.Category.Name</MudChip>
                    }
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@(habit.IsActive? Color.Success: Color.Default)">
                        @(habit.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </MudStack>
            </MudStack>
        </MudPaper>

        <!-- Main two-column layout -->
        <MudGrid Spacing="2">
            
            <!-- LEFT COLUMN -->
            <MudItem xs="12" md="6">
                
                <!-- Rank Information -->
                <MudPaper Elevation="4" Class="rounded pa-3 mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Rank Progress</MudText>
                    <MudStack Row="true" Spacing="2">
                        <MudPaper Elevation="0" Class="flex-grow-1 pa-2" Style="background-color: var(--mud-palette-action-default-hover); border-radius: var(--mud-default-borderradius);">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <div>
                                    <MudText Typo="Typo.caption">Current</MudText>
                                    <MudText Typo="Typo.h6" Color="Color.Primary">@habit.CurrentRank</MudText>
                                    <MudText Typo="Typo.caption">@habit.CurrentStreak days</MudText>
                                </div>
                                <MudImage Src="@($"/Images/Ranking_Images/{habit.CurrentRank}.png")" Width="40" Height="40" ObjectFit="ObjectFit.Contain" />
                            </MudStack>
                        </MudPaper>
                        <MudPaper Elevation="0" Class="flex-grow-1 pa-2" Style="background-color: var(--mud-palette-action-default-hover); border-radius: var(--mud-default-borderradius);">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <div>
                                    <MudText Typo="Typo.caption">Best Ever</MudText>
                                    <MudText Typo="Typo.h6" Color="Color.Warning">@habit.BeastRank</MudText>
                                    <MudText Typo="Typo.caption">@habit.BestStreak days</MudText>
                                </div>
                                <MudImage Src="@($"/Images/Ranking_Images/{habit.BeastRank}.png")" Width="40" Height="40" ObjectFit="ObjectFit.Contain" />
                            </MudStack>
                        </MudPaper>
                    </MudStack>
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.caption">Next rank: @GetNextRankThreshold(habit.CurrentStreak) days</MudText>
                    <MudProgressLinear Value="@GetProgressToNextRank(habit.CurrentStreak)" Color="Color.Primary" Rounded="true" Class="mt-1" Size="Size.Small" />
                </MudPaper>

               
                <!-- Habit Details -->
                <MudPaper Elevation="4" Class="rounded pa-3 mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Habit Details</MudText>
                    <MudSimpleTable Dense="true" Class="mt-2">
                        <tbody>
                            <tr>
                                <td><MudText Typo="Typo.body2" >Type</MudText></td>
                                <td><MudText Typo="Typo.body2"><strong>@habit.HabitType</strong></MudText></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2" >Goal Value</MudText></td>
                                <td><MudText Typo="Typo.body2"><strong>@habit.GoalValue</strong></MudText></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2" >Started</MudText></td>
                                <td><MudText Typo="Typo.body2">@habit.CreatedAt.ToString("MMM dd, yyyy")</MudText></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2" >Last Completed</MudText></td>
                                <td><MudText Typo="Typo.body2">@(habit.LastCompletedDate?.ToString("MMM dd, yyyy") ?? "Never")</MudText></td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>

            </MudItem>

            <!-- RIGHT COLUMN -->
            <MudItem xs="12" md="6">

                <!-- Consistency Section -->
                <MudPaper Elevation="4" Class="rounded pa-3 mb-3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                        <MudText Typo="Typo.subtitle2">Consistency Rate</MudText>
                        <MudChip T="string" Color="@GetConsistencyColor(habit.ConsistencyRate)" Size="Size.Small">@GetConsistencyLabel(habit.ConsistencyRate)</MudChip>
                    </MudStack>
                    <MudProgressLinear Value="@habit.ConsistencyRate" Color="@GetConsistencyColor(habit.ConsistencyRate)" Rounded="true" Size="Size.Small" />
                    <MudGrid Class="mt-3" Spacing="1">
                        <MudItem xs="4" Class="text-center">
                            <MudText Typo="Typo.body2" Style="font-weight:600;">@TotalDays</MudText>
                            <MudText Typo="Typo.caption">Total Days</MudText>
                        </MudItem>
                        <MudItem xs="4" Class="text-center">
                            <MudText Typo="Typo.body2" Style="font-weight:600; color:var(--mud-palette-success);">@CompletedDays</MudText>
                            <MudText Typo="Typo.caption">Completed</MudText>
                        </MudItem>
                        <MudItem xs="4" Class="text-center">
                            <MudText Typo="Typo.body2" Style="font-weight:600; color:var(--mud-palette-error);">@habit.TotalMissedDays</MudText>
                            <MudText Typo="Typo.caption">Missed</MudText>
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <!-- Stats Grid -->
                <MudPaper Elevation="4" Class="rounded pa-3 mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Statistics</MudText>
                    <MudGrid Spacing="1">
                        <MudItem xs="6" sm="3">
                            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                                <MudIcon Icon="@Icons.Material.Rounded.LocalFireDepartment" Color="Color.Error" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Style="font-weight:600;">@habit.CurrentStreak</MudText>
                                <MudText Typo="Typo.caption">Current Streak</MudText>
                            </MudStack>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                                <MudIcon Icon="@Icons.Material.Rounded.MilitaryTech" Color="Color.Warning" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Style="font-weight:600;">@habit.BestStreak</MudText>
                                <MudText Typo="Typo.caption">Best Streak</MudText>
                            </MudStack>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                                <MudIcon Icon="@Icons.Material.Rounded.PieChart" Color="Color.Success" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Style="font-weight:600;">@habit.ConsistencyRate<MudText Typo="Typo.caption" Inline="true">%</MudText></MudText>
                                <MudText Typo="Typo.caption">Consistency</MudText>
                            </MudStack>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                                <MudIcon Icon="@Icons.Material.Rounded.CalendarMonth" Color="Color.Error" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Style="font-weight:600;">@habit.TotalMissedDays</MudText>
                                <MudText Typo="Typo.caption">Missed Days</MudText>
                            </MudStack>
                        </MudItem>
                    </MudGrid>
                </MudPaper>


                <!-- Rest Days -->
                <MudPaper Elevation="4" Class="rounded pa-3 mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Rest Days</MudText>
                    
                    <MudText Typo="Typo.caption"  Class="mb-1">Weekly</MudText>
                    @if (habit.WeeklyRestDays.Any())
                    {
                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-3">
                            @foreach (var day in habit.WeeklyRestDays)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">@day.ToString()</MudChip>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="mb-3">— No weekly rest days —</MudText>
                    }

                    <MudText Typo="Typo.caption" Class="mb-1">Specific Dates</MudText>
                    @if (habit.SpecificRestDates.Any())
                    {
                        <MudStack Spacing="1">
                            @foreach (var date in habit.SpecificRestDates.OrderBy(d => d))
                            {
                                <MudText Typo="Typo.body2" Class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Rounded.Event" Size="Size.Small" Class="mr-1" />
                                    @date.ToString("MMM dd, yyyy")
                                </MudText>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">— No specific rest dates —</MudText>
                    }
                </MudPaper>

                <!-- Checklist Items -->
                @if (habit.HabitType == TypeOfHabit.List && habit.HabitListTemplates != null && habit.HabitListTemplates.Any())
                {
                    <MudPaper Elevation="4" Class="rounded pa-3 mb-3">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Checklist Items</MudText>
                        <MudStack Spacing="1">
                            @foreach (var item in habit.HabitListTemplates)
                            {
                                <MudPaper Elevation="0" Class="rounded pa-2" Style="border:1px solid var(--mud-palette-lines-default);">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="Icons.Material.Rounded.CheckCircleOutline" Color="Color.Primary" Size="Size.Small" />
                                        <MudText Typo="Typo.body2">@item.Name</MudText>
                                    </MudStack>
                                </MudPaper>
                            }
                        </MudStack>
                    </MudPaper>
                }

            </MudItem>

        </MudGrid>

        <!-- Rank Progression - Full width at bottom -->
        <MudPaper Elevation="4" Class="rounded pa-3 mb-3">
            <MudText Typo="Typo.subtitle2" Class="mb-2">All Ranks</MudText>
            <MudGrid Spacing="1">
                @foreach (var rank in AllRanks)
                {
                    bool isCurrent = rank.Name == habit.CurrentRank;
                    bool isBeast = rank.Name == habit.BeastRank;
                    bool isUnlocked = habit.CurrentStreak >= rank.Min || habit.BestStreak >= rank.Min;
                    <MudItem xs="3" sm="2" md="1">
                        <MudPaper Elevation="@(isCurrent ? 2 : 0)"
                                  Class="@($"rounded text-center pa-1 {(isCurrent ? "mud-theme-primary" : "")}")"
                                  Style="@($"border:1px solid var(--mud-palette-lines-default);{(isUnlocked ? "opacity:1" : "opacity:0.4")}")">
                            <MudImage Src="@($"/Images/Ranking_Images/{rank.Name}.png")" Width="24" Height="24" ObjectFit="ObjectFit.Contain" Class="mx-auto" />
                            <MudText Typo="Typo.caption" Style="font-size:10px;">@rank.Name</MudText>
                            @if (isCurrent)
                            {
                                <MudIcon Icon="Icons.Material.Rounded.Star" Color="Color.Primary" Size="Size.Small" Style="font-size:10px;" />
                            }
                            else if (isBeast)
                            {
                                <MudIcon Icon="Icons.Material.Rounded.Star" Color="Color.Warning" Size="Size.Small" Style="font-size:10px;" />
                            }
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        </MudPaper>

        <!-- Action Buttons -->
        <MudStack Row="true" Spacing="2" Class="mb-3">
            <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="Icons.Material.Rounded.ArrowBack" OnClick="GoBack" Size="Size.Small">Back</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="Icons.Material.Rounded.Edit" Href="@($"/Habits/Edit/{HabitId}")" Size="Size.Small">Edit Habit</MudButton>
        </MudStack>

    </MudContainer>
}

@code {
    [Parameter]
    public int HabitId { get; set; }

    private Habit? habit;
    private int TotalDays => habit?.TotalRequiredDays ?? 0;
    private int CompletedDays => (habit?.TotalRequiredDays ?? 0) - (habit?.TotalMissedDays ?? 0);

    private record RankEntry(string Name, int Min);
    private List<RankEntry> AllRanks = new()
    {
        new("Spark", 1), new("Ember", 3), new("Molten", 7), new("Warming", 10),
        new("Forming", 14), new("Stable", 21), new("Solid", 30), new("Shaped", 40),
        new("Forged", 50), new("Hardened", 65), new("Refined", 80), new("Tempered", 95),
        new("Mythic", 110), new("Legendary", 130), new("Unbreakable", 150)
    };

    protected override async Task OnInitializedAsync()
    {
        habit = await habitService.GetHabitbyIdAsync(HabitId);
        NavbarAsHeader.SetNavAsHeaderProperties(Icons.Material.Rounded.Info, "Habit Details", "habit details");
    }

    private void GoBack() => NavigationManager.NavigateTo("/Habits/Index");

    private Color GetConsistencyColor(double rate) => rate switch
    {
        >= 80 => Color.Success,
        >= 50 => Color.Warning,
        _ => Color.Error
    };

    private string GetConsistencyLabel(double rate) => rate switch
    {
        >= 80 => "Excellent",
        >= 60 => "Good",
        >= 40 => "Fair",
        _ => "Needs Work"
    };

    private int GetNextRankThreshold(int streak)
    {
        var next = AllRanks.FirstOrDefault(r => r.Min > streak);
        return next?.Min ?? AllRanks.Last().Min;
    }

    private double GetProgressToNextRank(int streak)
    {
        var current = AllRanks.LastOrDefault(r => r.Min <= streak);
        var next = AllRanks.FirstOrDefault(r => r.Min > streak);
        if (next == null) return 100;
        int from = current?.Min ?? 0;
        int to = next.Min;
        return Math.Round((double)(streak - from) / (to - from) * 100, 1);
    }
}