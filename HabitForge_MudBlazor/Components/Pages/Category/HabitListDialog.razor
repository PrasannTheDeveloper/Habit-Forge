@using MudBlazor
@using HabitForge_MudBlazor.Models

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-3 mb-n1" />
            Associated Habits
        </MudText>
    </TitleContent>
    
    <DialogContent>
        @if (Habits == null || !Habits.Any())
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                No habits found in this category.
            </MudAlert>
        }
        else
        {
            <MudList T="string" Clickable="false">
                @foreach (var habit in Habits)
                {
                    <MudListItem>
                        <ChildContent>
                            <div class="d-flex align-center">
                                <MudImage Src="@($"/Images/Ranking_Images/{habit.CurrentRank}.png")"
                                          Height="40"
                                          Width="40"
                                          ObjectFit="ObjectFit.Contain"
                                          Class="mr-4 rounded-lg"
                                          Alt="@habit.CurrentRank" />

                                <div class="d-flex flex-column">
                                    <MudText Typo="Typo.body1"><b>@habit.Name</b></MudText>
                                    <MudText Typo="Typo.caption">
                                        Rank: @habit.CurrentRank • Streak: @habit.CurrentStreak days
                                    </MudText>
                                </div>
                            </div>
                        </ChildContent>
                    </MudListItem>
                }
            </MudList>
        }
    </DialogContent>
    
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" FullWidth="true">
            Close
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public List<Habit> Habits { get; set; } = new();

    private void Submit() => MudDialog.Close(DialogResult.Ok(true));
}