@page "/ProgressDiary/Index"
@using HabitForge_MudBlazor.Models
@using HabitForge_MudBlazor.Services
@using MudBlazor
@inject ProgressDiaryService DiaryService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavManager
@inject NavbarAsHeaderService NavAsHeader

<MudContainer Class="pa-2">

@* ══════════════════════════════════════════════
       HEADER
    ══════════════════════════════════════════════ *@
@code {
    protected override async Task OnParametersSetAsync()
    {
        await NavAsHeader.SetNavAsHeaderProperties(Icons.Material.Filled.HistoryEdu, "Progress Journal", "Track your journey, one entry at a time");
    }
}

@* ══════════════════════════════════════════════
       STATS CARDS
    ══════════════════════════════════════════════ *@
<MudGrid Class="mb-6" Spacing="3">
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="3" Class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large">
                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" />
                </MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h5" Color="Color.Primary">@_diaries.Count</MudText>
                    <MudText Typo="Typo.caption">Total Entries</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="3" Class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudAvatar Color="Color.Success" Variant="Variant.Filled" Size="Size.Large">
                    <MudIcon Icon="@Icons.Material.Filled.Star" />
                </MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h5" Color="Color.Success">@_averageScore.ToString("F1")</MudText>
                    <MudText Typo="Typo.caption" >Avg Productivity</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="3" Class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudAvatar Color="Color.Warning" Variant="Variant.Filled" Size="Size.Large">
                    <MudIcon Icon="@Icons.Material.Filled.LocalFireDepartment" />
                </MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h5" Color="Color.Warning">@_thisWeekCount</MudText>
                    <MudText Typo="Typo.caption" >This Week</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="3" Class="pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudAvatar Color="Color.Info" Variant="Variant.Filled" Size="Size.Large">
                    <MudIcon Icon="@Icons.Material.Filled.Mood" />
                </MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h5" Color="Color.Info">@_topMood</MudText>
                    <MudText Typo="Typo.caption" >Most Common Mood</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@* ══════════════════════════════════════════════
       FILTERS
    ══════════════════════════════════════════════ *@
<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudGrid Spacing="2" AlignItems="AlignItems.Center">

        @* Search *@
        <MudItem xs="12" sm="6" md="4">
            <MudTextField Value="@_searchString"
                          ValueChanged="@((string v) => OnSearchChanged(v))"
                          Placeholder="Search by title or content..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Clearable="true"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          FullWidth="true"
                          Immediate="true" />
        </MudItem>

        @* Mood — plain HTML select *@
        <MudItem xs="12" sm="6" md="3">
            <div style="display:flex; flex-direction:column; gap:2px;">
                <select @onchange="OnMoodChanged" class="forge-select rounded-lg"
                        style="width:100%; padding:8px 10px; border-radius:6px;
                    border:1px solid #bbb; font-size:14px;
                    background:transparent; color:inherit; cursor:pointer;">
                    <option value="">— All Moods —</option>
                    @foreach (Moods m in Enum.GetValues(typeof(Moods)))
                    {
                        <option value="@m.ToString()">@m.ToString()</option>
                    }
                </select>
                <label style="font-size:11px; color:gray; margin-left:4px;">Filter by Mood</label>
            </div>
        </MudItem>

        @* Productivity Score — plain HTML select *@
        <MudItem xs="12" sm="6" md="3">
            <div style="display:flex; flex-direction:column; gap:2px;">
                <select @onchange="OnScoreChanged" class="forge-select rounded-lg"
                        style="width:100%; padding:8px 10px; border-radius:6px;
                    border:1px solid #bbb; font-size:14px;
                    background:transparent; color:inherit; cursor:pointer;">
                    <option value="">— All Scores —</option>
                    <option value="low">Low (1–4)</option>
                    <option value="mid">Medium (5–7)</option>
                    <option value="high">High (8–10)</option>
                </select>
                <label style="font-size:11px; color:gray; margin-left:4px;">Productivity Score</label>
            </div>
        </MudItem>

        @* Clear *@
        <MudItem xs="12" sm="6" md="2">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.FilterAltOff"
                       FullWidth="true"
                       OnClick="ClearFilters">
                Clear
            </MudButton>
        </MudItem>

    </MudGrid>
</MudPaper>

@* ══════════════════════════════════════════════
       TABLE
    ══════════════════════════════════════════════ *@
<MudTable Items="@_filteredDiaries"
          Hover="true"
          Breakpoint="Breakpoint.Sm"
          Loading="@_loading"
          LoadingProgressColor="Color.Primary"
          Elevation="4"
          Dense="false"
          SortLabel="Sort By">

    <ToolBarContent>
        <MudText Typo="Typo.h6">
            Your Journey
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="ml-2">
                @_filteredDiaries.Count entries
            </MudChip>
        </MudText>
        <MudSpacer />
    </ToolBarContent>

    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<ProgressDiary, object>(x => x.CreatedAt)">
                Date
            </MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<ProgressDiary, object>(x => x.Title)">
                Title
            </MudTableSortLabel>
        </MudTh>
        <MudTh>Mood</MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<ProgressDiary, object>(x => x.ProductivityScore)">
                Score
            </MudTableSortLabel>
        </MudTh>
        <MudTh>Win of Day</MudTh>
        <MudTh>Habits</MudTh>
        <MudTh Style="text-align:right">Actions</MudTh>
    </HeaderContent>

    <RowTemplate>
        @{
            var entryDate = context.CreatedAt;
            var entryTitle = context.Title ?? "Untitled";
            var entryTags = context.Tags ?? "";
            var entryMood = context.Mood;
            var entryScore = context.ProductivityScore < 1 ? 1 : context.ProductivityScore;
            var entryWin = context.WinOfDay ?? "";
            var entryHabits = context.RelatedHabits ?? new List<Habit>();
            var entryId = context.Id;
            var scoreValue = entryScore * 10;
        }

        <MudTd DataLabel="Date">
            <MudStack Spacing="0">
                <MudText Typo="Typo.body2" Style="font-weight:600">
                    @entryDate.ToString("MMM dd, yyyy")
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Success">
                    @entryDate.ToString("dddd")
                </MudText>
            </MudStack>
        </MudTd>

        <MudTd DataLabel="Title">
            <MudStack Spacing="0">
                <MudText Typo="Typo.body1" Style="font-weight:500">@entryTitle</MudText>
                @if (!string.IsNullOrWhiteSpace(entryTags))
                {
                    <MudText Typo="Typo.caption" Color="Color.Tertiary">@entryTags</MudText>
                }
            </MudStack>
        </MudTd>

        <MudTd DataLabel="Mood">
            <MudChip T="string"
                     Color="@GetMoodColor(entryMood)"
                     Size="Size.Small"
                     Variant="Variant.Filled">
                @entryMood.ToString()
            </MudChip>
        </MudTd>

        <MudTd DataLabel="Score">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudProgressLinear Color="@GetScoreColor(entryScore)"
                                   Min="0"
                                   Max="100"
                                   Value="@scoreValue"
                                   Style="width:80px; height:6px; border-radius:3px" />
                <MudText Typo="Typo.caption" Color="Color.Success">
                    @entryScore/10
                </MudText>
            </MudStack>
        </MudTd>

        <MudTd DataLabel="Win of Day">
            @if (!string.IsNullOrWhiteSpace(entryWin))
            {
                <MudTooltip Text="@entryWin" Placement="Placement.Top">
                    <MudText Typo="Typo.body2"
                             Style="max-width:160px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; display:block;">
                        @entryWin
                    </MudText>
                </MudTooltip>
            }
            else
            {
                <MudText Typo="Typo.caption" >—</MudText>
            }
        </MudTd>

        <MudTd DataLabel="Habits">
            @if (entryHabits.Any())
            {
                <MudChipSet T="string" ReadOnly="true">
                    @foreach (var habit in entryHabits.Take(2))
                    {
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="Color.Info"
                                 Variant="Variant.Outlined"
                                 Text="@(habit?.Name ?? "")" />
                    }
                    @if (entryHabits.Count > 2)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">
                            +@(entryHabits.Count - 2) more
                        </MudChip>
                    }
                </MudChipSet>
            }
            else
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">None linked</MudText>
            }
        </MudTd>

        <MudTd DataLabel="Actions" Style="text-align:right">
            <MudTooltip Text="View Entry">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                               Color="Color.Default"
                               Size="Size.Small"
                               OnClick="@(() => ViewEntry(entryId))" />
            </MudTooltip>
            <MudTooltip Text="Edit Entry">
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Color="Color.Primary"
                               Size="Size.Small"
                               OnClick="@(() => EditEntry(entryId))" />
            </MudTooltip>
            <MudTooltip Text="Delete Entry">
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Color="Color.Error"
                               Size="Size.Small"
                               OnClick="@(() => DeleteEntry(entryId))" />
            </MudTooltip>
        </MudTd>
    </RowTemplate>

    <NoRecordsContent>
        <MudStack AlignItems="AlignItems.Center" Class="py-8">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.h6" Color="Color.Secondary">No entries found</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Try adjusting your filters or create a new entry</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="CreateNew">
                New Entry
            </MudButton>
        </MudStack>
    </NoRecordsContent>

</MudTable>

</MudContainer>

@code {
    private List<ProgressDiary> _diaries = new();
    private List<ProgressDiary> _filteredDiaries = new();
    private bool _loading = true;

    // Filter state — all plain strings, no MudBlazor types involved
    private string _searchString = "";
    private string _moodFilterString = "";
    private string _scoreFilter = "";

    // ── Computed stats (always from full list) ────────────────────────────────
    private double _averageScore =>
        _diaries.Count > 0 ? _diaries.Average(d => d.ProductivityScore) : 0;

    private int _thisWeekCount =>
        _diaries.Count(d => d.CreatedAt >= DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek));

    private string _topMood =>
        _diaries.Count > 0
            ? _diaries.GroupBy(d => d.Mood)
                      .OrderByDescending(g => g.Count())
                      .First().Key.ToString()
            : "—";

    // ── Filter engine ─────────────────────────────────────────────────────────
    private void ApplyFilters()
    {
        _filteredDiaries = _diaries.Where(d =>
        {
            // Search
            if (!string.IsNullOrWhiteSpace(_searchString))
            {
                bool hit =
                    (d.Title?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (d.Content?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (d.Tags?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false);
                if (!hit) return false;
            }

            // Mood — string comparison, no enum casting
            if (!string.IsNullOrWhiteSpace(_moodFilterString))
            {
                if (!d.Mood.ToString().Equals(_moodFilterString, StringComparison.OrdinalIgnoreCase))
                    return false;
            }

            // Score
            if (!string.IsNullOrWhiteSpace(_scoreFilter))
            {
                var score = d.ProductivityScore;
                bool passes = _scoreFilter switch
                {
                    "low" => score >= 1 && score <= 4,
                    "mid" => score >= 5 && score <= 7,
                    "high" => score >= 8 && score <= 10,
                    _ => true
                };
                if (!passes) return false;
            }

            return true;
        }).ToList();
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            var data = await DiaryService.GetAllProgressDiariesAsync();
            _diaries = data ?? new List<ProgressDiary>();
            ApplyFilters();
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Filter handlers — ChangeEventArgs from native HTML, no MudBlazor ─────
    private void OnSearchChanged(string value)
    {
        _searchString = value ?? "";
        ApplyFilters();
    }

    private void OnMoodChanged(ChangeEventArgs e)
    {
        _moodFilterString = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void OnScoreChanged(ChangeEventArgs e)
    {
        _scoreFilter = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void ClearFilters()
    {
        _searchString = "";
        _moodFilterString = "";
        _scoreFilter = "";
        ApplyFilters();
    }

    // ── Navigation ────────────────────────────────────────────────────────────
    private void CreateNew() => NavManager.NavigateTo("/ProgressDiary/Create");
    private void ViewEntry(int id) => NavManager.NavigateTo($"/ProgressDiary/ViewEntry/{id}");
    private void EditEntry(int id) => NavManager.NavigateTo($"/ProgressDiary/Edit/{id}");

    // ── Delete ────────────────────────────────────────────────────────────────
    private async Task DeleteEntry(int id)
    {
        var parameters = new DialogParameters<MudMessageBox>();
        parameters.Add(x => x.Title, "Delete Entry");
        parameters.Add(x => x.Message, "Are you sure you want to delete this diary entry? This action cannot be undone.");
        parameters.Add(x => x.YesText, "Delete");
        parameters.Add(x => x.CancelText, "Cancel");

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Confirm Delete", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var success = await DiaryService.DeleteProgressDiaryAsync(id);
            Snackbar.Add(
                success ? "Entry deleted successfully." : "Failed to delete entry.",
                success ? Severity.Success : Severity.Error
            );
            if (success) await LoadData();
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    private Color GetMoodColor(Moods mood) => mood switch
    {
        Moods.Happy or Moods.Excited or Moods.Productive or Moods.Motivated or Moods.Inspired => Color.Success,
        Moods.Sad or Moods.BurntOut or Moods.Stressed or Moods.Frustrated => Color.Error,
        Moods.Anxious or Moods.Distracted or Moods.Tired => Color.Warning,
        Moods.Focused or Moods.Calm or Moods.Grateful or Moods.Reflective or Moods.Confident => Color.Info,
        _ => Color.Default
    };

    private Color GetScoreColor(int score) => score switch
    {
        >= 8 => Color.Success,
        >= 5 => Color.Warning,
        _ => Color.Error
    };
}
