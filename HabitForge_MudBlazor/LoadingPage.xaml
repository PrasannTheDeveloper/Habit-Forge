<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitForge_MudBlazor.LoadingPage"
             Title="LoadingPage">
    <VerticalStackLayout>
        <Label Text="HABIT FORGE" 
               TextColor="#FFD700" 
               FontSize="32" 
               FontAttributes="Bold"
               HorizontalOptions="Center" />
        <ActivityIndicator IsRunning="True" Color="#FFD700" />

        <Label 
            Text="Welcome to .NET MAUI!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>